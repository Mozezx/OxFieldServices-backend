# App
NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
# Bucket público para fotos de perfil (upload nos apps; PATCH /users/avatar-url valida este prefixo)
# AVATARS_STORAGE_BUCKET=avatars
# Service role JWT (Storage no evidence.service, Realtime broadcast para apps Flutter em app-sync-{authId})
SUPABASE_SERVICE_KEY=eyJxxxxx
# Opcional: mesmo valor que SUPABASE_SERVICE_KEY (alias suportado em AppSyncService)
# SUPABASE_SERVICE_ROLE_KEY=
# Runtime (Supabase): connection pooler — porta 6543; evita P1017 por conexões stale em API long-running.
# Acrescente ?pgbouncer=true à query string no dashboard da Supabase ao usar o pooler.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations / prisma migrate: conexão direta ao Postgres (porta 5432), não use pooler.
DIRECT_URL=postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres
# Postgres local: pode repetir o mesmo valor em DATABASE_URL e DIRECT_URL.

# JWT
JWT_SECRET=seu_secret_muito_longo_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=outro_secret_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Base URL da API (redirects Stripe Connect)
APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_51TS1t6KCZTCiiSRn6kYSlLcoX5H6FKeCZSaHk7JZ2erFvvFCSUiQi4VphQTkpMEF9dKej7qLvdVFyjBnfv1VpYOH00Ct0xrT44
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# PaymentIntent + Connect transfers (eur por defeito; use brl para contas Stripe Brasil)
STRIPE_CHARGE_CURRENCY=eur

# Stripe Connect — URLs após onboarding (defaults: APP_URL/payments/worker-account/onboarding/done|refresh)
# Opcional: STRIPE_CONNECT_RETURN_URL=https://api.seudominio.com/payments/worker-account/onboarding/done
# STRIPE_CONNECT_REFRESH_URL=https://api.seudominio.com/payments/worker-account/onboarding/refresh
# Deep link do app worker (botão na página HTML; mesmo scheme do Android/iOS, ex. io.oxapp.worker)
# STRIPE_CONNECT_APP_DEEP_LINK=io.oxapp.worker://connect-return

# Redis (Railway)
REDIS_URL=redis://default:xxxxx@xxxxx.railway.app:6379

# Firebase
FIREBASE_PROJECT_ID=ox-field-services
FIREBASE_PRIVATE_KEY=xxxxx
FIREBASE_CLIENT_EMAIL=xxxxx
