# App
NODE_ENV=development
PORT=3000

# Prisma (generate, migrate, studio) — use o Postgres local, não produção.
# Crie `ox-backend/.env.local` com DATABASE_URL e DIRECT_URL apontando para o host local
# (ex. Supabase CLI: `supabase start` → porta 54322) e rode: npm run db:generate, npm run db:migrate, etc.
# Exemplo (ajuste user/senha ao seu `supabase status`):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Opcional: origens extra para CORS (vírgulas). O código já permite localhost, LAN, *.ngrok, *.onrender.com e *.oxfieldservices.org (HTTPS).
# Use isto para outros domínios (ex. staging num host diferente).
# CORS_ALLOWED_ORIGINS=https://staging.example.com

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
# Bucket público para fotos de perfil (upload nos apps; PATCH /users/avatar-url valida este prefixo)
# AVATARS_STORAGE_BUCKET=avatars
# Service role JWT (Storage, Realtime app-sync-{authId}, e POST /admin/workers → auth.admin.createUser).
# Não uses a anon key aqui. Nunca expor esta chave no ox-admin nem nas apps móveis.
SUPABASE_SERVICE_KEY=eyJxxxxx
# Opcional: mesmo valor que SUPABASE_SERVICE_KEY (alias suportado em AppSyncService)
# SUPABASE_SERVICE_ROLE_KEY=
# Runtime (Supabase): connection pooler — porta 6543; evita P1017 por conexões stale em API long-running.
# Acrescente ?pgbouncer=true&connection_limit=10 (ou similar) à query string ao usar o pooler.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
# Migrations / prisma migrate: conexão direta ao Postgres (porta 5432), não use pooler.
DIRECT_URL=postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres
# Postgres local: pode repetir o mesmo valor em DATABASE_URL e DIRECT_URL.

# JWT
JWT_SECRET=seu_secret_muito_longo_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=outro_secret_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Base URL da API (redirects Stripe Connect)
APP_URL=http://localhost:3000
# URL pública para arquivos servidos pela API (ex.: vídeos em /uploads). Em LAN use o IP do PC, não localhost.
# APP_PUBLIC_URL=http://192.168.1.18:3000
# URL base do ox-admin (`/p/[token]`; campo `publicUrl` nas respostas). Dev típico: porta 3001 (npm run dev em ox-admin).
# Não use a mesma URL da API (PORT=3000), senão o link do cliente abre o Nest e devolve 404 JSON.
# CLIENT_PORTAL_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# PaymentIntent + Connect transfers (eur por defeito; use brl para contas Stripe Brasil)
STRIPE_CHARGE_CURRENCY=eur
# Valor mínimo do PaymentIntent em "centavos" da moeda (default Stripe comum: 50 = 0.50)
# STRIPE_MIN_CHARGE_AMOUNT_CENTS=50

# Stripe Connect — URLs após onboarding (defaults: APP_URL/payments/worker-account/onboarding/done|refresh)
# Em produção defina APP_URL com o URL público da API (HTTPS) para o Stripe redirecionar corretamente.
# Opcional: STRIPE_CONNECT_RETURN_URL=https://api.seudominio.com/payments/worker-account/onboarding/done
# STRIPE_CONNECT_REFRESH_URL=https://api.seudominio.com/payments/worker-account/onboarding/refresh
# Deep link para voltar ao app worker após o onboarding (override do default io.oxapp.worker://connect-return)
# STRIPE_CONNECT_APP_DEEP_LINK=io.oxapp.worker://connect-return

# Pagamento por invoice (Payment Link): redirect após checkout (default APP_URL/pay/{id}/success)
# INVOICE_PAYMENT_SUCCESS_URL=https://admin.seudominio.com/pay/callback

# Token HMAC para GET/POST públicos /invoices/:id/public e /invoices/:id/intent (recomendado dedicado)
# INVOICE_PUBLIC_TOKEN_SECRET=gerar_string_longa_aleatória

# Link público de acompanhamento /projects/public/:token (portal do cliente no ox-admin /project/:token)
# Se omitido, usa JWT_SECRET (mesmo padrão que invoices).
# OX_PROJECT_LINK_SECRET=gerar_string_longa_aleatória

# E-mail de cobrança (Resend) — https://resend.com
# RESEND_API_KEY=re_xxxx
# Remetente verificado no Resend (domínio ou sandbox onboarding@resend.dev)
# RESEND_FROM_EMAIL=OX <billing@seudominio.com>

# Taxa da plataforma em invoices (default 2.5). Modelo: pass-through (cliente paga subtotal+taxa) ou absorbed (taxa deduzida ao contratante).
# OX_PLATFORM_FEE_PERCENT=2.5
# OX_FEE_MODEL=pass-through

# URL base da página pública de pagamento (ox-admin /pay/[id]) para o botão "Pagar agora" no e-mail
# Se omitido, o e-mail usa o link do Stripe Payment Link.
# Local típico: http://localhost:3001/pay
# INVOICE_PAY_PUBLIC_BASE_URL=https://admin.seudominio.com/pay

# Redis (Railway) — necessário para Bull (filas: relatórios PDF, etc.)
REDIS_URL=redis://default:xxxxx@xxxxx.railway.app:6379

# Bucket público no Supabase Storage para PDFs de relatório (criar no dashboard se ainda não existir)
# REPORTS_STORAGE_BUCKET=project-reports

# DeepSeek (IA — legendas, checklists, resumo; formato API compatível com OpenAI)
# https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=
# Opcional: default https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# Modelo sugerido (multimodal): deepseek-v4-flash | deepseek-v4-pro | deepseek-chat
# DEEPSEEK_MODEL=deepseek-v4-flash

# Firebase
FIREBASE_PROJECT_ID=ox-field-services
FIREBASE_PRIVATE_KEY=xxxxx
FIREBASE_CLIENT_EMAIL=xxxxx
